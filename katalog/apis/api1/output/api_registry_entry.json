{
  "api_name": "Api1",
  "description": "Swagger Petstore sample API for managing pets, stores, and users.",
  "base_url": "/api/v3",
  "auth_method": "OAuth2",
  "auth_details": {
    "header_name": "Authorization",
    "token_env_var": "PETSTORE_OAUTH_TOKEN"
  },
  "rate_limit": "unknown",
  "docs_url": "https://github.com/swagger-api/swagger-petstore",
  "endpoints": [
    {
      "operation_id": "updatePet",
      "path": "/pet",
      "method": "PUT",
      "summary": "Update an existing pet.",
      "description": "Updates an existing pet by Id. Requires a full Pet object in the request body. Returns the updated Pet object. Edge cases include invalid or missing fields, nonexistent pets, or validation errors.",
      "tags": [
        "pet"
      ],
      "parameters": [],
      "request_body": {
        "content_type": "application/json",
        "schema_summary": "Pet object with id, name, photoUrls, category, tags, and status.",
        "example": {
          "id": 10,
          "name": "doggie",
          "photoUrls": [
            "url1"
          ],
          "status": "available"
        }
      },
      "responses": {
        "200": {
          "description": "Successful operation",
          "content_type": "application/json",
          "schema_summary": "Pet object with updated fields.",
          "example": {
            "id": 10,
            "name": "doggie",
            "photoUrls": [
              "url1"
            ],
            "status": "available"
          }
        },
        "400": {
          "description": "Invalid ID supplied",
          "example": {
            "error": "Invalid ID supplied"
          }
        },
        "404": {
          "description": "Pet not found",
          "example": {
            "error": "Pet not found"
          }
        },
        "422": {
          "description": "Validation exception",
          "example": {
            "error": "Validation exception"
          }
        }
      },
      "example_curl": "curl -X PUT '/api/v3/pet' -H 'Authorization: Bearer $PETSTORE_OAUTH_TOKEN' -H 'Content-Type: application/json' -d '{\"id\":10,\"name\":\"doggie\",\"photoUrls\":[\"url1\"]}'"
    },
    {
      "operation_id": "addPet",
      "path": "/pet",
      "method": "POST",
      "summary": "Add a new pet.",
      "description": "Creates a new pet in the store. Requires a Pet object in the request body. Edge cases include missing required fields or invalid structure.",
      "tags": [
        "pet"
      ],
      "parameters": [],
      "request_body": {
        "content_type": "application/json",
        "schema_summary": "Pet object with name and photoUrls required.",
        "example": {
          "name": "newdog",
          "photoUrls": [
            "url1"
          ]
        }
      },
      "responses": {
        "200": {
          "description": "Successful operation",
          "content_type": "application/json",
          "schema_summary": "Pet object created.",
          "example": {
            "id": 11,
            "name": "newdog",
            "photoUrls": [
              "url1"
            ],
            "status": "available"
          }
        },
        "400": {
          "description": "Invalid input",
          "example": {
            "error": "Invalid input"
          }
        },
        "422": {
          "description": "Validation exception",
          "example": {
            "error": "Validation exception"
          }
        }
      },
      "example_curl": "curl -X POST '/api/v3/pet' -H 'Authorization: Bearer $PETSTORE_OAUTH_TOKEN' -H 'Content-Type: application/json' -d '{\"name\":\"newdog\",\"photoUrls\":[\"url1\"]}'"
    },
    {
      "operation_id": "findPetsByStatus",
      "path": "/pet/findByStatus",
      "method": "GET",
      "summary": "Find pets by status.",
      "description": "Returns pets filtered by status. Multiple comma-separated statuses allowed.",
      "tags": [
        "pet"
      ],
      "parameters": [
        {
          "name": "status",
          "in": "query",
          "type": "string",
          "format": null,
          "required": true,
          "description": "Status to filter pets by.",
          "default": "available",
          "enum": [
            "available",
            "pending",
            "sold"
          ],
          "example": "available"
        }
      ],
      "responses": {
        "200": {
          "description": "successful operation",
          "content_type": "application/json",
          "schema_summary": "Array of Pet objects.",
          "example": [
            {
              "id": 10,
              "name": "doggie"
            }
          ]
        },
        "400": {
          "description": "Invalid status value",
          "example": {
            "error": "Invalid status value"
          }
        }
      },
      "example_curl": "curl -X GET '/api/v3/pet/findByStatus?status=available' -H 'Authorization: Bearer $PETSTORE_OAUTH_TOKEN'"
    },
    {
      "operation_id": "findPetsByTags",
      "path": "/pet/findByTags",
      "method": "GET",
      "summary": "Find pets by tags.",
      "description": "Returns pets filtered by tags. Query accepts comma-separated list.",
      "tags": [
        "pet"
      ],
      "parameters": [
        {
          "name": "tags",
          "in": "query",
          "type": "array",
          "format": null,
          "required": true,
          "description": "Tags to filter pets by.",
          "default": null,
          "enum": null,
          "example": "tag1,tag2"
        }
      ],
      "responses": {
        "200": {
          "description": "successful operation",
          "content_type": "application/json",
          "schema_summary": "Array of Pet objects.",
          "example": [
            {
              "id": 10,
              "name": "doggie"
            }
          ]
        },
        "400": {
          "description": "Invalid tag value",
          "example": {
            "error": "Invalid tag value"
          }
        }
      },
      "example_curl": "curl -X GET '/api/v3/pet/findByTags?tags=tag1,tag2' -H 'Authorization: Bearer $PETSTORE_OAUTH_TOKEN'"
    },
